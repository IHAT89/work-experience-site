{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard"],
  "timezone": "Asia/Singapore",
  "schedule": ["before 7am on monday"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "rangeStrategy": "bump",
  "commitMessagePrefix": "chore(deps):",
  "labels": ["dependencies"],

  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on sunday"]
  },

  "vulnerabilityAlerts": {
    "labels": ["dependencies", "security"],
    "schedule": ["at any time"],
    "prPriority": 10
  },

  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "enabled": false
    },
    {
      "description": "Auto-merge devDependency patch updates after CI passes",
      "matchUpdateTypes": ["patch"],
      "matchDepTypes": ["devDependencies"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Major updates always need manual review",
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "breaking-change"],
      "automerge": false
    },
    {
      "description": "Group Next.js ecosystem updates",
      "matchPackageNames": ["next", "react", "react-dom", "@next/{/,}**"],
      "groupName": "Next.js ecosystem",
      "automerge": false
    }
  ]
}
